# ── Database ──────────────────────────────────────────────────────────────────
# Local (Supabase postgres):
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/drl_sam
# Production (AWS RDS):
# DATABASE_URL=postgresql+asyncpg://user:pass@your-rds-host.rds.amazonaws.com:5432/drl_sam

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production-use-32-chars-min
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7
AUTH_PROVIDER=jwt   # set to 'saml' in production for SSO

# ── Storage ───────────────────────────────────────────────────────────────────
# Local — Supabase Storage API
STORAGE_BACKEND=supabase
SUPABASE_STORAGE_URL=http://storage:5000
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImV4cCI6MTk4MzgxMjk5Nn0.EGIM96RAZx35lJzdJsyH-qQwv8Hj04zWl196z2-SBc0

# Production — AWS S3 (comment out Supabase vars above when switching)
# STORAGE_BACKEND=s3
# AWS_ACCESS_KEY_ID=AKIA...
# AWS_SECRET_ACCESS_KEY=...
# AWS_REGION=ap-south-1
# AWS_S3_BUCKET_ACTIVE=drl-sam-active
# AWS_S3_BUCKET_ARCHIVE=drl-sam-archive

# ── AI ────────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Frontend ──────────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:8000/api/v1

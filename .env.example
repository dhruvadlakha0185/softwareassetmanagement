# ══════════════════════════════════════════════════════════════════════════════
# LOCAL DEVELOPMENT  (copy to .env, fill in SUPABASE_SERVICE_KEY)
# Prerequisites: run `supabase start` before `docker compose up`
# ══════════════════════════════════════════════════════════════════════════════

# Database — Supabase local Postgres (port from `supabase start`)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@host.docker.internal:54322/postgres

# Auth
JWT_SECRET=local-dev-secret-32chars-minimum-x
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7
AUTH_PROVIDER=jwt

# Storage — Supabase Storage via Kong gateway
STORAGE_BACKEND=supabase
SUPABASE_URL=http://host.docker.internal:54321
# Run `supabase status` and copy the "service_role key" here:
SUPABASE_SERVICE_KEY=

# AI
OPENAI_API_KEY=sk-...

# Frontend
VITE_API_URL=http://localhost:8000/api/v1


# ══════════════════════════════════════════════════════════════════════════════
# PRODUCTION  (set via AWS SSM / ECS task definition secrets)
# ══════════════════════════════════════════════════════════════════════════════

# DATABASE_URL=postgresql+asyncpg://postgres:PASSWORD@db:5432/drl_sam
#   (or RDS endpoint: ...rds.amazonaws.com:5432/drl_sam)

# JWT_SECRET=<strong random 32+ char secret>
# AUTH_PROVIDER=jwt   # or 'saml' for SSO

# STORAGE_BACKEND=s3
# AWS_ACCESS_KEY_ID=AKIA...
# AWS_SECRET_ACCESS_KEY=...
# AWS_REGION=ap-south-1
# AWS_S3_BUCKET_ACTIVE=drl-sam-active
# AWS_S3_BUCKET_ARCHIVE=drl-sam-archive

# OPENAI_API_KEY=sk-...
# POSTGRES_PASSWORD=<strong password for bundled postgres>
